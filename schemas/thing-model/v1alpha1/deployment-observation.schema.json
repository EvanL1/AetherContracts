{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.aether.dev/schemas/thing-model/v1alpha1/deployment-observation.schema.json",
  "title": "Aether Thing Model deployment observation v1 alpha 1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "gateway_id", "desired", "reported", "applied", "observed_at_ms"],
  "properties": {
    "schema": { "const": "aether.thing-model.deployment-observation.v1alpha1" },
    "gateway_id": { "$ref": "#/$defs/uuid" },
    "desired": { "$ref": "#/$defs/desiredReference" },
    "reported": { "$ref": "#/$defs/reportedReference" },
    "applied": { "$ref": "#/$defs/appliedReference" },
    "observed_at_ms": { "$ref": "#/$defs/uint64" }
  },
  "$defs": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-8][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "uint64": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20,
      "pattern": "^(0|[1-9][0-9]{0,18}|1[0-7][0-9]{18}|18[0-3][0-9]{17}|184[0-3][0-9]{16}|1844[0-5][0-9]{15}|18446[0-6][0-9]{14}|184467[0-3][0-9]{13}|1844674[0-3][0-9]{12}|184467440[0-6][0-9]{10}|1844674407[0-2][0-9]{9}|18446744073[0-6][0-9]{8}|1844674407370[0-8][0-9]{6}|18446744073709[0-4][0-9]{5}|184467440737095[0-4][0-9]{4}|18446744073709550[0-9]{3}|18446744073709551[0-5][0-9]{2}|1844674407370955160[0-9]|1844674407370955161[0-5])$"
    },
    "positiveUint64": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20,
      "pattern": "^([1-9][0-9]{0,18}|1[0-7][0-9]{18}|18[0-3][0-9]{17}|184[0-3][0-9]{16}|1844[0-5][0-9]{15}|18446[0-6][0-9]{14}|184467[0-3][0-9]{13}|1844674[0-3][0-9]{12}|184467440[0-6][0-9]{10}|1844674407[0-2][0-9]{9}|18446744073[0-6][0-9]{8}|1844674407370[0-8][0-9]{6}|18446744073709[0-4][0-9]{5}|184467440737095[0-4][0-9]{4}|18446744073709550[0-9]{3}|18446744073709551[0-5][0-9]{2}|1844674407370955160[0-9]|1844674407370955161[0-5])$"
    },
    "modelReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_id", "revision", "digest"],
      "properties": {
        "model_id": {
          "type": "string",
          "minLength": 3,
          "maxLength": 160,
          "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$"
        },
        "revision": { "$ref": "#/$defs/positiveUint64" },
        "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    },
    "desiredReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "model", "updated_at_ms"],
      "properties": {
        "state": { "const": "desired" },
        "model": { "$ref": "#/$defs/modelReference" },
        "updated_at_ms": { "$ref": "#/$defs/uint64" }
      }
    },
    "reportedReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "supported_models", "reported_at_ms"],
      "properties": {
        "state": { "const": "reported" },
        "supported_models": {
          "type": "array",
          "maxItems": 256,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/modelReference" }
        },
        "reported_at_ms": { "$ref": "#/$defs/uint64" }
      }
    },
    "appliedReference": {
      "oneOf": [
        { "$ref": "#/$defs/notAppliedReference" },
        { "$ref": "#/$defs/applyingReference" },
        { "$ref": "#/$defs/appliedEvidenceReference" },
        { "$ref": "#/$defs/failedReference" }
      ]
    },
    "notAppliedReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "model", "evidence"],
      "properties": {
        "state": { "const": "not-applied" },
        "model": { "type": "null" },
        "evidence": { "$ref": "#/$defs/evidence" }
      }
    },
    "applyingReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "model", "evidence"],
      "properties": {
        "state": { "const": "applying" },
        "model": { "$ref": "#/$defs/modelReference" },
        "evidence": { "$ref": "#/$defs/evidence" }
      }
    },
    "appliedEvidenceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "model", "evidence", "applied_at_ms"],
      "properties": {
        "state": { "const": "applied" },
        "model": { "$ref": "#/$defs/modelReference" },
        "evidence": { "$ref": "#/$defs/evidence" },
        "applied_at_ms": { "$ref": "#/$defs/uint64" }
      }
    },
    "failedReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "model", "evidence"],
      "properties": {
        "state": { "const": "failed" },
        "model": { "$ref": "#/$defs/modelReference" },
        "evidence": { "$ref": "#/$defs/evidence" }
      }
    },
    "evidence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    }
  }
}
