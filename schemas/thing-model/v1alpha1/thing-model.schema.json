{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.aether.dev/schemas/thing-model/v1alpha1/thing-model.schema.json",
  "title": "Aether Thing Model v1 alpha 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "model_id",
    "revision",
    "title",
    "profiles",
    "properties",
    "points",
    "capabilities"
  ],
  "properties": {
    "schema": { "const": "aether.thing-model.v1alpha1" },
    "model_id": { "$ref": "#/$defs/modelId" },
    "revision": { "$ref": "#/$defs/positiveUint64" },
    "title": { "$ref": "#/$defs/title" },
    "description": { "type": "string", "maxLength": 2048 },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "extends": {
      "type": "array",
      "maxItems": 16,
      "items": { "$ref": "#/$defs/modelReference" }
    },
    "legacy_aliases": {
      "type": "array",
      "maxItems": 32,
      "items": { "$ref": "#/$defs/legacyAlias" }
    },
    "properties": {
      "type": "array",
      "maxItems": 1024,
      "items": { "$ref": "#/$defs/propertyDefinition" }
    },
    "points": {
      "type": "array",
      "maxItems": 4096,
      "items": { "$ref": "#/$defs/pointDefinition" }
    },
    "capabilities": {
      "type": "array",
      "maxItems": 256,
      "items": { "$ref": "#/$defs/capabilityDefinition" }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "modelId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 160,
      "pattern": "^[a-z][a-z0-9]*(?:[._-][a-z0-9]+)+$"
    },
    "key": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96,
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "positiveUint64": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20,
      "pattern": "^([1-9][0-9]{0,18}|1[0-7][0-9]{18}|18[0-3][0-9]{17}|184[0-3][0-9]{16}|1844[0-5][0-9]{15}|18446[0-6][0-9]{14}|184467[0-3][0-9]{13}|1844674[0-3][0-9]{12}|184467440[0-6][0-9]{10}|1844674407[0-2][0-9]{9}|18446744073[0-6][0-9]{8}|1844674407370[0-8][0-9]{6}|18446744073709[0-4][0-9]{5}|184467440737095[0-4][0-9]{4}|18446744073709550[0-9]{3}|18446744073709551[0-5][0-9]{2}|1844674407370955160[0-9]|1844674407370955161[0-5])$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "valueType": {
      "enum": ["boolean", "int64", "uint64", "float64", "decimal", "string", "bytes"]
    },
    "modelReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_id", "revision", "digest"],
      "properties": {
        "model_id": { "$ref": "#/$defs/modelId" },
        "revision": { "$ref": "#/$defs/positiveUint64" },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "legacyAlias": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "kind", "id"],
      "properties": {
        "namespace": { "$ref": "#/$defs/identifier" },
        "kind": { "$ref": "#/$defs/identifier" },
        "id": { "type": "string", "minLength": 1, "maxLength": 128 }
      }
    },
    "unit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["symbol"],
      "properties": {
        "symbol": { "type": "string", "minLength": 1, "maxLength": 32 },
        "ucum_code": { "type": "string", "minLength": 1, "maxLength": 64 },
        "legacy_symbol": { "type": "string", "maxLength": 32 }
      }
    },
    "parameterDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "title", "value_type", "required"],
      "properties": {
        "key": { "$ref": "#/$defs/key" },
        "title": { "$ref": "#/$defs/title" },
        "value_type": { "$ref": "#/$defs/valueType" },
        "required": { "type": "boolean" },
        "unit": { "$ref": "#/$defs/unit" }
      }
    },
    "propertyDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "title", "value_type", "authority", "change_path"],
      "properties": {
        "key": { "$ref": "#/$defs/key" },
        "title": { "$ref": "#/$defs/title" },
        "description": { "type": "string", "maxLength": 1024 },
        "value_type": { "$ref": "#/$defs/valueType" },
        "unit": { "$ref": "#/$defs/unit" },
        "authority": { "const": "artifact-revision" },
        "change_path": { "enum": ["artifact-deployment", "edge-local-only"] },
        "legacy_aliases": {
          "type": "array",
          "maxItems": 16,
          "items": { "$ref": "#/$defs/legacyAlias" }
        }
      }
    },
    "pointDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "title", "kind", "value_type", "authority", "access"],
      "properties": {
        "key": { "$ref": "#/$defs/key" },
        "title": { "$ref": "#/$defs/title" },
        "description": { "type": "string", "maxLength": 1024 },
        "kind": { "enum": ["telemetry", "status", "event"] },
        "value_type": { "$ref": "#/$defs/valueType" },
        "unit": { "$ref": "#/$defs/unit" },
        "authority": { "const": "edge" },
        "access": { "const": "read-only" },
        "legacy_aliases": {
          "type": "array",
          "maxItems": 16,
          "items": { "$ref": "#/$defs/legacyAlias" }
        }
      }
    },
    "capabilityDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "title",
        "parameters",
        "execution",
        "default_authorization",
        "permission",
        "risk",
        "confirmation",
        "idempotency",
        "expiry",
        "audit",
        "edge_final_decision"
      ],
      "properties": {
        "key": { "$ref": "#/$defs/key" },
        "title": { "$ref": "#/$defs/title" },
        "description": { "type": "string", "maxLength": 1024 },
        "parameters": {
          "type": "array",
          "maxItems": 64,
          "items": { "$ref": "#/$defs/parameterDefinition" }
        },
        "execution": { "const": "governed-job" },
        "default_authorization": { "const": "deny" },
        "permission": { "$ref": "#/$defs/identifier" },
        "risk": { "enum": ["low", "medium", "high", "critical"] },
        "confirmation": { "enum": ["none", "required"] },
        "idempotency": { "const": "required" },
        "expiry": { "const": "required" },
        "audit": { "const": "required" },
        "edge_final_decision": { "const": true },
        "legacy_aliases": {
          "type": "array",
          "maxItems": 16,
          "items": { "$ref": "#/$defs/legacyAlias" }
        }
      }
    }
  }
}
