{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.aether.dev/schemas/integration/v1alpha1/integration-observation-batch.schema.json",
  "title": "Aether integration observation batch v1 alpha 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "integration_id",
    "snapshot_generation",
    "batch_id",
    "observed_at_ms",
    "observations"
  ],
  "properties": {
    "schema": { "const": "aether.integration.observation-batch.v1alpha1" },
    "integration_id": { "$ref": "#/$defs/identifier" },
    "snapshot_generation": { "$ref": "#/$defs/uint64" },
    "batch_id": { "$ref": "#/$defs/identifier" },
    "observed_at_ms": { "$ref": "#/$defs/uint64" },
    "observations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 65536,
      "items": { "$ref": "#/$defs/observation" }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "uint64": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20,
      "pattern": "^(0|[1-9][0-9]{0,18}|1[0-7][0-9]{18}|18[0-3][0-9]{17}|184[0-3][0-9]{16}|1844[0-5][0-9]{15}|18446[0-6][0-9]{14}|184467[0-3][0-9]{13}|1844674[0-3][0-9]{12}|184467440[0-6][0-9]{10}|1844674407[0-2][0-9]{9}|18446744073[0-6][0-9]{8}|1844674407370[0-8][0-9]{6}|18446744073709[0-4][0-9]{5}|184467440737095[0-4][0-9]{4}|18446744073709550[0-9]{3}|18446744073709551[0-5][0-9]{2}|1844674407370955160[0-9]|1844674407370955161[0-5])$"
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entity_id",
        "point_key",
        "observed_at_ms",
        "quality"
      ],
      "properties": {
        "entity_id": { "$ref": "#/$defs/identifier" },
        "point_key": { "$ref": "#/$defs/identifier" },
        "observed_at_ms": { "$ref": "#/$defs/uint64" },
        "quality": {
          "enum": ["good", "uncertain", "bad", "unavailable"]
        },
        "value": {
          "$ref": "https://contracts.aether.dev/schemas/integration/v1alpha1/observed-value.schema.json"
        },
        "diagnostic": {
          "$ref": "#/$defs/evidenceText"
        }
      }
    },
    "evidenceText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[^\\u0000-\\u001F\\u007F]*[^\\s\\u0000-\\u001F\\u007F][^\\u0000-\\u001F\\u007F]*$"
    }
  }
}
