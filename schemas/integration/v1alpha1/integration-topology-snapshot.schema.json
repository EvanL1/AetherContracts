{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.aether.dev/schemas/integration/v1alpha1/integration-topology-snapshot.schema.json",
  "title": "Aether integration topology snapshot v1 alpha 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "integration_id",
    "integration_kind",
    "snapshot_generation",
    "observed_at_ms",
    "areas",
    "devices",
    "entities"
  ],
  "properties": {
    "schema": { "const": "aether.integration.topology-snapshot.v1alpha1" },
    "integration_id": { "$ref": "#/$defs/identifier" },
    "integration_kind": { "$ref": "#/$defs/identifier" },
    "snapshot_generation": { "$ref": "#/$defs/uint64" },
    "observed_at_ms": { "$ref": "#/$defs/uint64" },
    "areas": {
      "type": "array",
      "maxItems": 4096,
      "items": { "$ref": "#/$defs/area" }
    },
    "devices": {
      "type": "array",
      "maxItems": 16384,
      "items": { "$ref": "#/$defs/device" }
    },
    "entities": {
      "type": "array",
      "maxItems": 65536,
      "items": { "$ref": "#/$defs/entity" }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "displayText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[^\\u0000-\\u001F\\u007F]*[^\\s\\u0000-\\u001F\\u007F][^\\u0000-\\u001F\\u007F]*$"
    },
    "versionText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[^\\u0000-\\u001F\\u007F]*[^\\s\\u0000-\\u001F\\u007F][^\\u0000-\\u001F\\u007F]*$"
    },
    "uint64": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20,
      "pattern": "^(0|[1-9][0-9]{0,18}|1[0-7][0-9]{18}|18[0-3][0-9]{17}|184[0-3][0-9]{16}|1844[0-5][0-9]{15}|18446[0-6][0-9]{14}|184467[0-3][0-9]{13}|1844674[0-3][0-9]{12}|184467440[0-6][0-9]{10}|1844674407[0-2][0-9]{9}|18446744073[0-6][0-9]{8}|1844674407370[0-8][0-9]{6}|18446744073709[0-4][0-9]{5}|184467440737095[0-4][0-9]{4}|18446744073709550[0-9]{3}|18446744073709551[0-5][0-9]{2}|1844674407370955160[0-9]|1844674407370955161[0-5])$"
    },
    "area": {
      "type": "object",
      "additionalProperties": false,
      "required": ["area_id", "name"],
      "properties": {
        "area_id": { "$ref": "#/$defs/identifier" },
        "name": { "$ref": "#/$defs/displayText" }
      }
    },
    "device": {
      "type": "object",
      "additionalProperties": false,
      "required": ["device_id", "name"],
      "properties": {
        "device_id": { "$ref": "#/$defs/identifier" },
        "name": { "$ref": "#/$defs/displayText" },
        "area_id": { "$ref": "#/$defs/identifier" },
        "manufacturer": { "$ref": "#/$defs/displayText" },
        "model": { "$ref": "#/$defs/displayText" },
        "software_version": { "$ref": "#/$defs/versionText" },
        "hardware_version": { "$ref": "#/$defs/versionText" }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entity_id",
        "source_address",
        "name",
        "entity_kind",
        "points"
      ],
      "properties": {
        "entity_id": { "$ref": "#/$defs/identifier" },
        "source_address": { "$ref": "#/$defs/identifier" },
        "name": { "$ref": "#/$defs/displayText" },
        "entity_kind": { "$ref": "#/$defs/identifier" },
        "device_id": { "$ref": "#/$defs/identifier" },
        "area_id": { "$ref": "#/$defs/identifier" },
        "points": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": { "$ref": "#/$defs/entityPointDescriptor" }
        }
      }
    },
    "entityPointDescriptor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["point_key", "title", "kind", "value_type"],
      "properties": {
        "point_key": { "$ref": "#/$defs/identifier" },
        "title": { "$ref": "#/$defs/displayText" },
        "kind": { "enum": ["telemetry", "status", "event"] },
        "value_type": {
          "enum": [
            "boolean",
            "int64",
            "uint64",
            "float64",
            "decimal",
            "string",
            "bytes"
          ]
        },
        "unit": { "type": "string", "minLength": 1, "maxLength": 32 }
      }
    }
  }
}
