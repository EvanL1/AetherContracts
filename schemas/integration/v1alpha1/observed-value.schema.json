{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.aether.dev/schemas/integration/v1alpha1/observed-value.schema.json",
  "title": "Aether integration observed value v1 alpha 1",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": { "const": "boolean" },
        "value": { "type": "boolean" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": { "const": "int64" },
        "value": { "$ref": "#/$defs/int64" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": { "const": "uint64" },
        "value": { "$ref": "#/$defs/uint64" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": { "const": "float64" },
        "value": { "type": "number" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": { "const": "decimal" },
        "value": { "$ref": "#/$defs/decimal" }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "value"],
      "properties": {
        "type": { "const": "string" },
        "value": { "type": "string", "maxLength": 4096 }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "encoding", "value"],
      "properties": {
        "type": { "const": "bytes" },
        "encoding": { "const": "base64url" },
        "value": { "$ref": "#/$defs/base64url" }
      }
    }
  ],
  "$defs": {
    "int64": {
      "type": "string",
      "anyOf": [
        {
          "pattern": "^(?:0|[1-9][0-9]{0,17}|[1-8][0-9]{18}|9[0-1][0-9]{17}|92[0-1][0-9]{16}|922[0-2][0-9]{15}|9223[0-2][0-9]{14}|92233[0-6][0-9]{13}|922337[0-1][0-9]{12}|92233720[0-2][0-9]{10}|922337203[0-5][0-9]{9}|9223372036[0-7][0-9]{8}|92233720368[0-4][0-9]{7}|922337203685[0-3][0-9]{6}|9223372036854[0-6][0-9]{5}|92233720368547[0-6][0-9]{4}|922337203685477[0-4][0-9]{3}|9223372036854775[0-7][0-9]{2}|922337203685477580[0-7])$"
        },
        {
          "pattern": "^-(?:[1-9][0-9]{0,17}|[1-8][0-9]{18}|9[0-1][0-9]{17}|92[0-1][0-9]{16}|922[0-2][0-9]{15}|9223[0-2][0-9]{14}|92233[0-6][0-9]{13}|922337[0-1][0-9]{12}|92233720[0-2][0-9]{10}|922337203[0-5][0-9]{9}|9223372036[0-7][0-9]{8}|92233720368[0-4][0-9]{7}|922337203685[0-3][0-9]{6}|9223372036854[0-6][0-9]{5}|92233720368547[0-6][0-9]{4}|922337203685477[0-4][0-9]{3}|9223372036854775[0-7][0-9]{2}|922337203685477580[0-8])$"
        }
      ]
    },
    "uint64": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20,
      "pattern": "^(0|[1-9][0-9]{0,18}|1[0-7][0-9]{18}|18[0-3][0-9]{17}|184[0-3][0-9]{16}|1844[0-5][0-9]{15}|18446[0-6][0-9]{14}|184467[0-3][0-9]{13}|1844674[0-3][0-9]{12}|184467440[0-6][0-9]{10}|1844674407[0-2][0-9]{9}|18446744073[0-6][0-9]{8}|1844674407370[0-8][0-9]{6}|18446744073709[0-4][0-9]{5}|184467440737095[0-4][0-9]{4}|18446744073709550[0-9]{3}|18446744073709551[0-5][0-9]{2}|1844674407370955160[0-9]|1844674407370955161[0-5])$"
    },
    "decimal": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96,
      "pattern": "^(?:0|-?[1-9][0-9]*|-?(?:0|[1-9][0-9]*)\\.[0-9]*[1-9])$"
    },
    "base64url": {
      "type": "string",
      "maxLength": 16384,
      "pattern": "^(?:[A-Za-z0-9_-]{4})*(?:[A-Za-z0-9_-][AQgw]|[A-Za-z0-9_-]{2}[AEIMQUYcgkosw048])?$"
    }
  }
}
