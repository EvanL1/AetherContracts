{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.aether.dev/schemas/integration-control/v1alpha1/integration-action-intent.schema.json",
  "title": "Aether governed Integration power-set intent v1 alpha 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "capability_id",
    "target",
    "arguments",
    "governance",
    "authorization",
    "confirmation"
  ],
  "properties": {
    "schema": {
      "const": "aether.integration-control.action-intent.v1alpha1"
    },
    "capability_id": { "const": "device.power.set.v1" },
    "target": { "$ref": "#/$defs/target" },
    "arguments": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value"],
      "properties": {
        "value": { "type": "boolean" }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution",
        "default_authorization",
        "permission",
        "risk",
        "confirmation",
        "idempotency",
        "expiry",
        "audit",
        "edge_final_decision"
      ],
      "properties": {
        "execution": { "const": "governed-job" },
        "default_authorization": { "const": "deny" },
        "permission": { "const": "integration.device.control" },
        "risk": { "const": "high" },
        "confirmation": { "const": "required" },
        "idempotency": { "const": "required" },
        "expiry": { "const": "required" },
        "audit": { "const": "required" },
        "edge_final_decision": { "const": true }
      }
    },
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_decision_id",
        "subject_id",
        "permission",
        "authorized_at_ms"
      ],
      "properties": {
        "policy_decision_id": { "$ref": "#/$defs/identifier" },
        "subject_id": { "$ref": "#/$defs/identifier" },
        "permission": { "const": "integration.device.control" },
        "authorized_at_ms": { "$ref": "#/$defs/uint64" }
      }
    },
    "confirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confirmation_id", "subject_id", "confirmed_at_ms"],
      "properties": {
        "confirmation_id": { "$ref": "#/$defs/uuid" },
        "subject_id": { "$ref": "#/$defs/identifier" },
        "confirmed_at_ms": { "$ref": "#/$defs/uint64" }
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-8][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "uint64": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20,
      "pattern": "^(0|[1-9][0-9]{0,18}|1[0-7][0-9]{18}|18[0-3][0-9]{17}|184[0-3][0-9]{16}|1844[0-5][0-9]{15}|18446[0-6][0-9]{14}|184467[0-3][0-9]{13}|1844674[0-3][0-9]{12}|184467440[0-6][0-9]{10}|1844674407[0-2][0-9]{9}|18446744073[0-6][0-9]{8}|1844674407370[0-8][0-9]{6}|18446744073709[0-4][0-9]{5}|184467440737095[0-4][0-9]{4}|18446744073709550[0-9]{3}|18446744073709551[0-5][0-9]{2}|1844674407370955160[0-9]|1844674407370955161[0-5])$"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "integration_id",
        "snapshot_generation",
        "entity_id",
        "point_key"
      ],
      "properties": {
        "integration_id": { "$ref": "#/$defs/identifier" },
        "snapshot_generation": { "$ref": "#/$defs/uint64" },
        "entity_id": { "$ref": "#/$defs/identifier" },
        "point_key": { "const": "is_on" }
      }
    }
  }
}
