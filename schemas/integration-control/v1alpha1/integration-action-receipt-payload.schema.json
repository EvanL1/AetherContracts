{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.aether.dev/schemas/integration-control/v1alpha1/integration-action-receipt-payload.schema.json",
  "title": "Aether governed Integration action receipt payload v1 alpha 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "job_id",
    "receipt_id",
    "receipt_sequence",
    "capability_id",
    "target",
    "intent_digest",
    "stage",
    "decision",
    "physical_outcome",
    "observed_at_ms",
    "audit"
  ],
  "properties": {
    "schema": {
      "const": "aether.integration-control.action-receipt.v1alpha1"
    },
    "job_id": { "$ref": "#/$defs/uuid" },
    "receipt_id": { "$ref": "#/$defs/uuid" },
    "receipt_sequence": { "$ref": "#/$defs/positiveUint64" },
    "capability_id": { "const": "device.power.set.v1" },
    "target": {
      "$ref": "integration-action-intent.schema.json#/$defs/target"
    },
    "intent_digest": { "$ref": "#/$defs/digest" },
    "stage": {
      "enum": [
        "edge-accepted",
        "edge-rejected",
        "provider-accepted",
        "provider-rejected",
        "unknown"
      ]
    },
    "decision": { "enum": ["accepted", "rejected", "unknown"] },
    "physical_outcome": { "const": "unknown" },
    "observed_at_ms": { "$ref": "#/$defs/uint64" },
    "evidence_digest": { "$ref": "#/$defs/digest" },
    "failure_code": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["audit_record_id", "status"],
      "properties": {
        "audit_record_id": { "$ref": "#/$defs/identifier" },
        "status": { "enum": ["complete", "incomplete"] }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "stage": { "enum": ["edge-accepted", "provider-accepted"] }
        },
        "required": ["stage"]
      },
      "then": {
        "properties": { "decision": { "const": "accepted" } },
        "not": { "required": ["failure_code"] }
      }
    },
    {
      "if": {
        "properties": {
          "stage": { "enum": ["edge-rejected", "provider-rejected"] }
        },
        "required": ["stage"]
      },
      "then": {
        "required": ["failure_code"],
        "properties": { "decision": { "const": "rejected" } }
      }
    },
    {
      "if": {
        "properties": { "stage": { "const": "unknown" } },
        "required": ["stage"]
      },
      "then": {
        "required": ["failure_code"],
        "properties": { "decision": { "const": "unknown" } }
      }
    },
    {
      "if": {
        "properties": {
          "stage": {
            "enum": ["provider-accepted", "provider-rejected"]
          }
        },
        "required": ["stage"]
      },
      "then": { "required": ["evidence_digest"] }
    },
    {
      "if": {
        "properties": { "stage": { "const": "edge-accepted" } },
        "required": ["stage"]
      },
      "then": { "not": { "required": ["evidence_digest"] } }
    }
  ],
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-8][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "uint64": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20,
      "pattern": "^(0|[1-9][0-9]{0,18}|1[0-7][0-9]{18}|18[0-3][0-9]{17}|184[0-3][0-9]{16}|1844[0-5][0-9]{15}|18446[0-6][0-9]{14}|184467[0-3][0-9]{13}|1844674[0-3][0-9]{12}|184467440[0-6][0-9]{10}|1844674407[0-2][0-9]{9}|18446744073[0-6][0-9]{8}|1844674407370[0-8][0-9]{6}|18446744073709[0-4][0-9]{5}|184467440737095[0-4][0-9]{4}|18446744073709550[0-9]{3}|18446744073709551[0-5][0-9]{2}|1844674407370955160[0-9]|1844674407370955161[0-5])$"
    },
    "positiveUint64": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20,
      "pattern": "^([1-9][0-9]{0,18}|1[0-7][0-9]{18}|18[0-3][0-9]{17}|184[0-3][0-9]{16}|1844[0-5][0-9]{15}|18446[0-6][0-9]{14}|184467[0-3][0-9]{13}|1844674[0-3][0-9]{12}|184467440[0-6][0-9]{10}|1844674407[0-2][0-9]{9}|18446744073[0-6][0-9]{8}|1844674407370[0-8][0-9]{6}|18446744073709[0-4][0-9]{5}|184467440737095[0-4][0-9]{4}|18446744073709550[0-9]{3}|18446744073709551[0-5][0-9]{2}|1844674407370955160[0-9]|1844674407370955161[0-5])$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
